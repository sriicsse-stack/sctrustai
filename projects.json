        "path": "app/components/Calculator.tsx",
        "content": "import React, { useState } from 'react';\nimport './Calculator.css';\n\nconst Calculator: React.FC = () => {\n  const [input, setInput] = useState('');\n  const [prevValue, setPrevValue] = useState<string | null>(null);\n  const [operator, setOperator] = useState<string | null>(null);\n\n  const handleClick = (value: string) => {\n    if (/\\[0-9.]/.test(value)) {\n      setInput(input + value);\n    } else if (value === 'C') {\n      setInput('');\n      setPrevValue(null);\n      setOperator(null);\n    } else if (value === '=') {\n      if (prevValue && operator) {\n        try {\n          // Using Function constructor for simplicity in this mock, \n          // but be cautious in production with untrusted input.\n          const result = new Function('a', 'b', `return ${prevValue} ${operator} ${input}`)();\n          setInput(result.toString());\n          setPrevValue(null);\n          setOperator(null);\n        } catch {\n          setInput('Error');\n        }\n      }\n    } else {\n      if (input) {\n        setPrevValue(input);\n        setOperator(value);\n        setInput('');\n      }\n    }\n  };\n\n  const buttons = [\n    { value: '7', className: 'naruto-button' },\n    { value: '8', className: 'naruto-button' },\n    { value: '9', className: 'naruto-button' },\n    { value: '/', className: 'naruto-operator' },\n    { value: '4', className: 'naruto-button' },\n    { value: '5', className: 'naruto-button' },\n    { value: '6', className: 'naruto-button' },\n    { value: '*', className: 'naruto-operator' },\n    { value: '1', className: 'naruto-button' },\n    { value: '2', className: 'naruto-button' },\n    { value: '3', className: 'naruto-button' },\n    { value: '-', className: 'naruto-operator' },\n    { value: '0', className: 'naruto-button' },\n    { value: '.', className: 'naruto-button' },\n    { value: '=', className: 'naruto-operator equals' },\n    { value: '+', className: 'naruto-operator' },\n    { value: 'C', className: 'naruto-clear' },\n  ];\n\n  return (\n    <div className=\"naruto-calculator shadow-xl border-4 border-red-800\">\n      <div className=\"naruto-display p-5 text-4xl font-bold text-white text-right bg-black/50 rounded-t-lg \">\n        {input || '0'}\n      </div>\n      <div className=\"naruto-buttons grid grid-cols-4 gap-3 p-5\">\n        {buttons.map((button) => (\n          <button\n            key={button.value}\n            className={` ${button.className} text-white font-bold py-3 px-4 rounded-lg text-2xl transition-transform duration-200 hover:scale-105 hover:brightness-125 focus:outline-none focus:ring-2 focus:ring-offset-2 ${button.className === 'naruto-clear' ? 'bg-red-600 hover:bg-red-700 focus:ring-red-500' : button.className.includes('operator') ? 'bg-yellow-600 hover:bg-yellow-700 focus:ring-yellow-500' : 'bg-gray-700 hover:bg-gray-800 focus:ring-gray-500'}`}\n            onClick={() => handleClick(button.value)}\n          >\n            {button.value === '*' ? '×' : button.value === '/' ? '÷' : button.value}\n          </button>\n        ))}\n      </div>\n    </div>\n  );\n};\n\nexport default Calculator;\n"
      },
      {
        "path": "app/components/Calculator.css",
        "content": "/* Styles inspired by Naruto theme */\nbody {\n  background: linear-gradient(135deg, #ff7a00, #feda74, #ff0000);\n  font-family: 'Inter', sans-serif;\n}\n\n.naruto-calculator {\n  background-color: rgba(0, 0, 0, 0.8);\n  border-radius: 15px;\n  box-shadow: 0 0 20px rgba(255, 100, 0, 0.5), 0 0 40px rgba(255, 0, 0, 0.3);\n  overflow: hidden;\n  width: 100%;\n  max-width: 350px;\n  border: 4px solid #a04000;\n}\n\n.naruto-display {\n  background-color: #1a1a1a;\n  color: #fff;\n  font-family: 'Space Grotesk', sans-serif;\n  text-shadow: 0 0 5px rgba(255, 165, 0, 0.8);\n  border-bottom: 4px solid #a04000;\n}\n\n.naruto-buttons {\n  padding: 20px;\n}\n\n.naruto-button,\n.naruto-operator,\n.naruto-clear {\n  background-color: #333;\n  color: #fff;\n  border: none;\n  cursor: pointer;\n  font-weight: bold;\n  transition: all 0.2s ease;\n  box-shadow: inset 0 -3px #555;\n  text-transform: uppercase;\n  font-size: 1.8rem;\n  border-radius: 10px;\n}\n\n.naruto-button:hover,\n.naruto-operator:hover,\n.naruto-clear:hover {\n  filter: brightness(1.2);\n}\n\n.naruto-button:active,\n.naruto-operator:active,\n.naruto-clear:active {\n  transform: translateY(2px);\n  box-shadow: none;\n}\n\n.naruto-operator {\n  background-color: #ffcc00;\n  color: #333;\n  box-shadow: inset 0 -3px #ccaa00;\n}\n\n.naruto-operator:hover {\n  background-color: #e6b800;\n}\n\n.naruto-clear {\n  background-color: #cc0000;\n  color: #fff;\n  box-shadow: inset 0 -3px #990000;\n}\n\n.naruto-clear:hover {\n  background-color: #aa0000;\n}\n\n.equals {\n  background-color: #ff4500;\n  color: #fff;\n  box-shadow: inset 0 -3px #cc3300;\n}\n\n.equals:hover {\n  background-color: #e03c00;\n}\n\n/* Media query for smaller screens */\n@media (max-width: 400px) {\n  .naruto-calculator {\n    max-width: 300px;\n  }\n  .naruto-display {\n    font-size: 2.8rem;\n    padding: 15px;\n  }\n  .naruto-buttons {\n    padding: 15px;\n    gap: 10px;\n  }\n  .naruto-button,\n  .naruto-operator,\n  .naruto-clear {\n    font-size: 1.5rem;\n    padding: 10px;\n  }\n}\n"
      },
