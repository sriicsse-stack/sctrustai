    "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Naruto Calculator</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/tailwindcss@^2.2.19/dist/tailwind.min.css\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Space+Grotesk:wght@700&display=swap\" rel=\"stylesheet\">\n    <style>\n        /* Inline CSS for demonstration */\n        body {\n            background: linear-gradient(135deg, #a04000, #ffb74d, #cc0000);\n            font-family: 'Inter', sans-serif;\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 1rem;\n        }\n\n        .naruto-calculator {\n            background-color: rgba(0, 0, 0, 0.8);\n            border-radius: 15px;\n            box-shadow: 0 0 20px rgba(255, 100, 0, 0.5), 0 0 40px rgba(255, 0, 0, 0.3);\n            overflow: hidden;\n            width: 100%;\n            max-width: 350px;\n            border: 4px solid #a04000;\n        }\n\n        .naruto-display {\n            background-color: #1a1a1a;\n            color: #fff;\n            font-family: 'Space Grotesk', sans-serif;\n            text-shadow: 0 0 5px rgba(255, 165, 0, 0.8);\n            border-bottom: 4px solid #a04000;\n            font-size: 2.8rem; /* Increased size */\n            padding: 1.25rem 1.5rem; /* Adjusted padding */\n            text-align: right;\n            border-top-left-radius: 10px; /* Match calculator */ \n            border-top-right-radius: 10px;\n        }\n\n        .naruto-buttons {\n            padding: 1.5rem;\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 0.75rem; /* Adjusted gap */\n        }\n\n        .naruto-button,\n        .naruto-operator,\n        .naruto-clear {\n            background-color: #333;\n            color: #fff;\n            border: none;\n            cursor: pointer;\n            font-weight: bold;\n            transition: all 0.2s ease;\n            box-shadow: inset 0 -3px #555;\n            text-transform: uppercase;\n            font-size: 1.8rem;\n            padding: 0.75rem 1rem;\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .naruto-button:hover,\n        .naruto-operator:hover,\n        .naruto-clear:hover {\n            filter: brightness(1.2);\n        }\n\n        .naruto-button:active,\n        .naruto-operator:active,\n        .naruto-clear:active {\n            transform: translateY(2px);\n            box-shadow: none;\n        }\n\n        .naruto-operator {\n            background-color: #ffcc00;\n            color: #333;\n            box-shadow: inset 0 -3px #ccaa00;\n        }\n\n        .naruto-operator:hover {\n            background-color: #e6b800;\n        }\n\n        .naruto-clear {\n            background-color: #cc0000;\n            color: #fff;\n            box-shadow: inset 0 -3px #990000;\n        }\n\n        .naruto-clear:hover {\n            background-color: #aa0000;\n        }\n\n        .equals {\n            background-color: #ff4500;\n            color: #fff;\n            box-shadow: inset 0 -3px #cc3300;\n            grid-column: span 2; /* Make equals button wider */\n        }\n\n        .equals:hover {\n            background-color: #e03c00;\n        }\n\n        /* Media query for smaller screens */\n        @media (max-width: 400px) {\n          .naruto-calculator {\n            max-width: 300px;\n          }\n          .naruto-display {\n            font-size: 2.5rem;\n            padding: 1rem 1.25rem;\n          }\n          .naruto-buttons {\n            padding: 1rem;\n            gap: 0.5rem;\n          }\n          .naruto-button,\n          .naruto-operator,\n          .naruto-clear {\n            font-size: 1.5rem;\n            padding: 0.75rem;\n          }\n          .equals {\n             grid-column: span 2;\n          }\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"calculator-root\"></div>\n\n<script>\n    // Mock React component for standalone HTML\n    class Calculator extends React.Component {\n        constructor(props) {\n            super(props);\n            this.state = {\n                input: '',\n                prevValue: null,\n                operator: null,\n                displayValue: '0'\n            };\n        }\n\n        handleClick(value) {\n            const { input, prevValue, operator, displayValue } = this.state;\n\n            if (/[0-9.]/.test(value)) {\n                this.setState({\n                    input: input + value,\n                    displayValue: input + value\n                });\n            } else if (value === 'C') {\n                this.setState({\n                    input: '',\n                    prevValue: null,\n                    operator: null,\n                    displayValue: '0'\n                });\n            } else if (value === '=') {\n                if (prevValue && operator) {\n                    try {\n                        // Using Function constructor for simplicity\n                        const result = new Function('a', 'b', `return ${prevValue} ${operator} ${input}`)();\n                        this.setState({\n                            input: '',\n                            prevValue: null,\n                            operator: null,\n                            displayValue: result.toString()\n                        });\n                    } catch (e) {\n                        this.setState({\n                            input: '',\n                            prevValue: null,\n                            operator: null,\n                            displayValue: 'Error'\n                        });\n                    }\n                }\n            } else {\n                if (input) {\n                    this.setState({\n                        prevValue: input,\n                        operator: value,\n                        input: '',\n                        displayValue: input // Show current input before clearing for next number\n                    });\n                }\n            }\n        }\n\n        render() {\n            const buttons = [\n                { value: '7', className: 'naruto-button' },\n                { value: '8', className: 'naruto-button' },\n                { value: '9', className: 'naruto-button' },\n                { value: '/', className: 'naruto-operator' },\n                { value: '4', className: 'naruto-button' },\n                { value: '5', className: 'naruto-button' },\n                { value: '6', className: 'naruto-button' },\n                { value: '*', className: 'naruto-operator' },\n                { value: '1', className: 'naruto-button' },\n                { value: '2', className: 'naruto-button' },\n                { value: '3', className: 'naruto-button' },\n                { value: '-', className: 'naruto-operator' },\n                { value: '0', className: 'naruto-button' },\n                { value: '.', className: 'naruto-button' },\n                { value: '=', className: 'naruto-operator equals' },\n                { value: '+', className: 'naruto-operator' },\n                { value: 'C', className: 'naruto-clear' },\n            ];\n\n            return (\n                <div className=\"naruto-calculator shadow-xl border-4 border-red-800\">\n                    <div className=\"naruto-display\">\n                        {this.state.displayValue}\n                    </div>\n                    <div className=\"naruto-buttons\">\n                        {buttons.map(button => (\n                            <button\n                                key={button.value}\n                                className={`${button.className} text-white font-bold py-3 px-4 rounded-lg text-2xl transition-transform duration-200 hover:scale-105 hover:brightness-125 focus:outline-none focus:ring-2 focus:ring-offset-2 ${button.className === 'naruto-clear' ? 'bg-red-600 hover:bg-red-700 focus:ring-red-500' : button.className.includes('operator') ? 'bg-yellow-600 hover:bg-yellow-700 focus:ring-yellow-500' : 'bg-gray-700 hover:bg-gray-800 focus:ring-gray-500'}`}\n                                onClick={() => this.handleClick(button.value)}\n                            >\n                                {button.value === '*' ? '×' : button.value === '/' ? '÷' : button.value}\n                            </button>\n                        ))}\n                    </div>\n                </div>\n            );\n        }\n    }\n\n    // Render the component\n    ReactDOM.render(\n        <Calculator />,\n        document.getElementById('calculator-root')\n    );\n</script>\n\n</body>\n</html>\n",
